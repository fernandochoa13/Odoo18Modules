<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="documents_account_quickbuttons.DetailsPanelPatch"
       t-inherit="documents.DocumentsDetailsPanel"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_field_widget') and hasclass('o_field_many2many_tags')]"
               position="after">
            <div t-if="showQuickButtons"
                 class="o_documents_quick_accounting mt-3 pt-2 border-top"
                 t-on-focusin="ensureFieldsLoaded"
                 t-on-mouseenter="ensureFieldsLoaded">
                <div class="mb-2">
                    <label class="fw-bold text-muted small d-block mb-1">Invoice Number</label>
                    <input type="text"
                           class="form-control form-control-sm"
                           t-att-value="quickFields.doc_invoice_ref"
                           t-on-change="(ev) =&gt; this.saveQuickField('doc_invoice_ref', ev)"
                           placeholder="Invoice #"/>
                </div>
                <div class="mb-2">
                    <label class="fw-bold text-muted small d-block mb-1">Invoice Date</label>
                    <input type="date"
                           class="form-control form-control-sm"
                           t-att-value="quickFields.doc_invoice_date"
                           t-on-change="(ev) =&gt; this.saveQuickField('doc_invoice_date', ev)"/>
                </div>
                <div class="row mb-2">
                    <div class="col-6">
                        <label class="fw-bold text-muted small d-block mb-1">Payment Type</label>
                        <select class="form-select form-select-sm"
                                t-on-change="(ev) =&gt; this.saveQuickField('doc_payment_type', ev)">
                            <option value="">-- Select --</option>
                            <option value="check"
                                    t-att-selected="quickFields.doc_payment_type === 'check'">Check</option>
                            <option value="credit"
                                    t-att-selected="quickFields.doc_payment_type === 'credit'">Credit/ACH</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="fw-bold text-muted small d-block mb-1">Due Date</label>
                        <input type="date"
                               class="form-control form-control-sm"
                               t-att-value="quickFields.doc_payment_due_date"
                               t-on-change="(ev) =&gt; this.saveQuickField('doc_payment_due_date', ev)"/>
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap mt-3">
                    <button type="button"
                            class="btn btn-primary btn-sm flex-grow-1"
                            t-on-click="onCreateVendorBill">
                        <i class="fa fa-file-text-o me-1"/>Create Vendor Bill
                    </button>
                    <button type="button"
                            class="btn btn-outline-secondary btn-sm flex-grow-1"
                            t-on-click="onCreateCustomerInvoice">
                        <i class="fa fa-file-o me-1"/>Create Customer Invoice
                    </button>
                </div>
                <button t-if="isLinkedToMove"
                        type="button"
                        class="btn btn-success btn-sm w-100 mt-2"
                        t-on-click="onRegisterPayment">
                    <i class="fa fa-money me-1"/>Register Payment
                </button>
            </div>
        </xpath>
    </t>
</templates>
