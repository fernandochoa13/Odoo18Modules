<record id="view_invoice_form_inherit" model="ir.ui.view">
    <field name="name">account.move.form.inherit</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
        <xpath expr="//header" position="after">
            <div class="alert alert-warning d-flex align-items-center justify-content-between o_row" role="alert" invisible="['|', ('lock_on_coc', '!=', True), '|', ('coc_approved', '=', True), '|', ('state', '!=', 'draft'), ('move_type', '!=', 'out_invoice')]">
                <p class="mb-0">
                    You must request approval for invoices made for properties on status COC.
                </p>
                <button name="action_approve_coc"
                        string="Approve"
                        type="object"
                        class="btn"
                        icon="fa-check"
                        invisible="[('is_invoice_admin', '=', False)]"/>
            </div>
            <div class="alert alert-success o_row" role="alert" invisible="['|', ('coc_approved', '=', False), '|', ('state', '=', 'posted'), '|', ('move_type', '!=', 'out_invoice'), ('move_type', '!=', 'out_invoice')]">
                <p class="mb-0">
                    The invoice has been approved.
                </p>
            </div>
        </xpath>
        <xpath expr="//form" position="attributes">
            <attribute name="delete">false</attribute>
        </xpath>
        <xpath expr="//field[@name='name']" position="attributes">
            <attribute name="readonly">false</attribute> 
        </xpath>
            <!-- Changing readonly here -->
        <xpath expr="//group[@id='header_right_group']/field[@name='date']" position="replace">
            <field name="date" string="Accounting Date"
                invisible="[('move_type', 'in', ('out_invoice', 'out_refund', 'out_receipt')), ('quick_edit_mode', '=', False)]" readonly="[('state', '=', 'cancel')]"/>

            <!-- <attribute name="attrs">
                {
                    'invisible': [('move_type', 'in', ('out_invoice', 'out_refund', 'out_receipt')), ('quick_edit_mode', '=', False)],
                    'readonly': [('state', '=', 'cancel')],
                }
            </attribute> -->
        </xpath>
        <xpath expr="//field[@name='partner_id']" position="after">
                <field name="budget_date" invisible="[('move_type', '!=', 'entry')]"/>
                <field name="invoice_vendor_bill_id" string="Auto-complete" optional="show"
                       domain="[('partner_id', '=', partner_id), ('company_id', '=', company_id)]"
                       invisible="[('move_type', '!=', 'in_invoice')]"/>
                <field name="linked_material_order" string="Linked Material Order" invisible="True"/>
                <!-- <field name="date_receipted" invisible="[('move_type', '!=', 'in_invoice')]"/> -->
                <field name="property_id" invisible="1"/>
                <field name="linked_activities" string="Linked Activity" options="{'no_create': True}" domain="[('vendor', '=', partner_id), ('project_property.address', '=', property_id)]"/>
                <field name="linked_activities_end_date" string="Activity End Date"/>
                <field name="activity_completed" string="Linked Activity Completed"/>
                <field name="date_paid"/>
                <field name="completed_date"/>
                <field name="linked_contractor_job" options="{'no_create': True}"/>
                <field name="invoice_filter_type" invisible="[('move_type', '!=', 'out_invoice')]"/>
                <!-- invisible="[('move_type', '!=', 'in_invoice')]"
                invisible="[('move_type', '!=', 'in_invoice')]" -->
        </xpath>
        <!-- <xpath expr="//group[@id='header_right_group']/field[@name='journal_id']" position="after">
        </xpath> -->
        <xpath expr="//notebook" position="inside">
                <page string="Property Details">
                    <group>
                        <group>
                            <field name="property_id"/>
                            <field name="status_property"/>
                            <field name="custodial_money"/>
                            <field name="property_house_model"/>
                        </group>
                        <group>
                            <field name="lock_on_coc"/>
                            <field name="coc_approved"/>
                            <field name="is_invoice_admin"/>
                        </group>
                    </group>
                </page>
        </xpath>
        <xpath expr="//field[@name='product_id']" position="after">
            <field name="subproducts" optional="hide"/>
            <field name="activity" optional="hide"/>
        </xpath>
        <xpath expr="//field[@name='analytic_distribution']" position="after">
            <field name="billable" optional="show"/>
            <field name="markup" optional="show"/>
        </xpath>
