<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="ir_cron_update_project_duration_from_invoices" model="ir.cron">
            <field name="name">Update Project Duration from Invoice Reports</field>
            <field name="model_id" ref="model_pms_projects"/>
            <field name="code">model.search([])._compute_project_duration_from_invoices()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
        <record id="ir_cron_1099_compliance_check" model="ir.cron">
            <field name="name">1099 Compliance Weekly Check</field>
            <field name="model_id" ref="pms.model_vendor_1099_compliance"/>
            <field name="code">model.run_compliance_check()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
</odoo>

