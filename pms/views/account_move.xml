<odoo>

<record id="view_invoice_tree_inherit" model="ir.ui.view">
    <field name="name">account.move.tree.inherit</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_invoice_tree"/>
    <field name="arch" type="xml">
        <xpath expr="//list" position="attributes">
            <attribute name="delete">false</attribute>
        </xpath>
        <xpath expr="//field[@name='date']" position="after">
            <!-- <field name="invoice_type" optional="show"/> -->
            <!-- <field name="on_hold_comments" optional="hide"/> -->
            <!-- <field name="analytic_accounts" optional="show"/> -->
            <!-- <field name="product_inv" optional="show"/> -->
            <field name="contractor" optional="show"/>
            <field name="invoice_filter_type" optional="show"/>
            <field name="activity_completed" optional="show"/>
            <field name="invoice_payment_classification" optional="show"/>
            <field name="triggers_on_hold" optional="hide"/>

        </xpath>
        <xpath expr="//field[@name='state']" position="after">
            <!-- <field name="last_customer_message" optional="show"/> -->
            <field name="bill_alert" optional="hide"/>
            <!-- <field name="note_inv" optional="show"/> -->
            <!-- Included House Model Field -->
            <!-- <field name="house_model" optional="show"/> -->
        </xpath>
    </field>
</record>

<record id="view_account_invoice_filter_inherit" model="ir.ui.view">
    <field name="name">account.invoice.select.inherit</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_account_invoice_filter"/>
    <field name="arch" type="xml">
        <xpath expr="//search/field[@name='partner_id']" position="after">
            <field name="analytic_accounts" string="Analytic Accounts"/>
            <field name="contractor" string="Contractor"/>
        </xpath>
    </field>
</record>


<record id="view_move_line_form_inherit" model="ir.ui.view">
    <field name="name">account.move.line.form.inherit</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
        <xpath expr="//page[@name='other_info']/group[@id='other_tab_group']/group[@name='sale_info_group']" position="inside">
            <!-- Add your custom field here -->
            <field name="invoice_link_docs"/>
        </xpath>
        <xpath expr="//field[@name='line_ids']//field[@name='partner_id']" position="after">
            <field name="product_id" optional="show"/>

            <!--Journal Items = aml_tab-->
        </xpath>
        <xpath expr="//header" position="inside">
                    <button name="open_mail_messages"
                            type="object"
                            string="Related Messages"
                            class="oe_highlight"
                            invisible="[('move_type', 'not in', ('out_invoice', 'out_refund', 'in_invoice', 'in_refund'))]"
                            data-hotkey="b"/>
        </xpath>
        <xpath expr="//header" position="inside">
                    <button name="open_intercompany_payment"
                            type="object"
                            string="Intercompany Payment"
                            class="oe_highlight"
                            invisible="['|', ('state', '!=', 'posted'), '|', ('move_type', 'not in', ('in_invoice', 'in_refund')), ('payment_state', '=', 'paid')]"
                            data-hotkey="b"/>
        </xpath>
        <!-- <xpath expr="//header" position="inside">
                    <button name="create_material_order"
                            type="object"
                            string="Create Material Order"
                            class="oe_highlight"
                            invisible="[('move_type', 'not in', ('in_invoice', 'in_refund'))]"
                            data-hotkey="b"/>
        </xpath> -->

        <xpath expr="//field[@name='ref']" position="after">
            <field name="contractor"/>
            <field name="contractor_date" invisible="[('move_type', '!=', 'out_invoice')]"/>
            <field name="utility_account_number"/>
            <field name="utility_pin"/>
            <!-- Included House Model Field -->
            <!-- <field name="house_model" optional="show"/> -->
        </xpath>

        <xpath expr="//field[@name='payment_reference']" position="after">
            <field name="invoice_payment_classification"
                   invisible="[('move_type', 'not in', ('out_invoice', 'in_invoice'))]"/>
            <field name="triggers_on_hold" readonly="1" 
                   invisible="[('move_type', 'not in', ('out_invoice', 'in_invoice'))]"/>
            <field name="payment_type_bills" invisible="[('move_type', '!=', 'in_invoice')]"/>
            <field name="employee_id" invisible="[('move_type', '!=', 'in_invoice')]"/>
            <field name="invoice_user_id" invisible="[('move_type', '!=', 'in_invoice')]"/>
            <!-- <field name="service_fee" invisible="[('move_type', '!=', 'out_invoice')]"/> -->
            <field name="service_fee"/>
        </xpath>
        <xpath expr="//field[@name='purchase_vendor_bill_id']" position="after">
            <field name="priority" invisible="[('move_type', '!=', 'in_invoice')]" widget="priority"/>
        </xpath>
        
        <xpath expr="//page[@name='other_info']" position="after">
            <page name="related_documents" string="Related Documents" invisible="[('move_type', 'not in', ('in_invoice', 'out_invoice'))]">
                <group>
                    <group name="sales_info" invisible="[('move_type', '!=', 'in_invoice')]">
                        <field name="related_invoice_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        <field name="total_related_sales" widget="monetary"/>
                        <field name="profit_amount" widget="monetary"/>
                        <field name="profit_margin" widget="percentage"/>
                    </group>
                    <group name="purchase_info" invisible="[('move_type', '!=', 'out_invoice')]">
                        <field name="related_bill_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        <field name="total_related_purchases" widget="monetary"/>
                        <field name="profit_amount" widget="monetary"/>
                        <field name="profit_margin" widget="percentage"/>
                    </group>
                </group>
                <!-- <group>
                    <button name="action_auto_link_bills_invoices" 
                            string="🔗 Auto-Link Invoices &amp; Bills" 
                            type="object" 
                            class="btn btn-primary oe_highlight"
                            style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; padding: 12px 24px; font-weight: bold; font-size: 14px; border-radius: 8px; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4); transition: all 0.3s ease; color: white;"
                            help="Automatically find and link related documents based on products, analytic accounts, and dates"/>
                </group> -->
            </page>
        </xpath>
    </field>
</record>


