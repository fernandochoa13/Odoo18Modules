    <record id="bill_report_action_clear_links" model="ir.actions.server">
        <field name="name">Clear Invoice Links</field>
        <field name="type">ir.actions.server</field>
        <field name="model_id" ref="pms.model_bill_report"/>
        <field name="binding_model_id" ref="pms.model_bill_report"/>
        <field name="code">
bills = env['account.move'].browse(records.mapped('bill_id').ids)
for bill in bills:
    bill.write({'related_invoice_ids': [(5, 0, 0)]})
if len(bills) > 1:
    message = 'Cleared invoice links from %s bills.' % len(bills)
else:
    message = 'Cleared invoice links from bill.'
action = {
    'type': 'ir.actions.client',
    'tag': 'display_notification',
    'params': {
        'title': 'Links Cleared',
        'message': message,
        'sticky': False,
        'type': 'success',
    }
}
        </field>
    </record>

